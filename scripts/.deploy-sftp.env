# Copy to: scripts/.deploy-sftp.env

SFTP_HOST=5019616186.ssh.w2.strato.hosting
SFTP_PORT=22
SFTP_USER=su228795

# Absolute target directory on server, e.g. /var/www/nochda
REMOTE_PATH=/

# 1 = show actions only, 0 = upload files
DRY_RUN=0

# 1 = upload .env.local too (careful with secrets), 0 = do not upload
UPLOAD_ENV_FILE=0

# 1 = delete remote files that are missing locally (mirror --delete), 0 = keep remote extras
DELETE_REMOTE_MISSING=1

# 1 = delete remote Symfony cache directories (var/cache/prod|dev|test) before upload
CLEAR_REMOTE_CACHE=1
