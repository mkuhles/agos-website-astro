---
interface Props {
  className?: string;
  id?: string;
}

let { className, id } = Astro.props
if (!id) {
  id = 'flip-card-' + Math.random().toString(36).substring(2, 9);
}
--- 

<div class={ className + ' flip-card'}
    id={id}
    tabindex="0"
    role="button"
    aria-controls={id + '-inner'}
    aria-expanded="false"
>
    <div class='flip-card-inner flip-trigger' aria-label="Vorderseite" id={id + '-inner'}>
        <div class="flip-card-front">
            <slot name="front" />
        </div>
        <div class="flip-card-back flip-trigger" aria-label="Rückseite">
            <slot name="back" />
        </div>
    </div>
</div>

<style lang="scss" scoped>

*:focus,
*:focus-visible {
  outline: 2px dashed var(--black);
  outline-offset: 1vmin;
  border-radius: 50%;
}
</style>

<script>
  import { toggleCardMobile, requestReflow } from "./flip-card";
  import { isSmallScreen } from "../../scripts/media";
  
  document.addEventListener("click", (e) => {
    if (!isSmallScreen()) return;

    const target = e.target instanceof HTMLElement ? e.target : null;
    const card = target?.closest(".flip-card");
    if (!(card instanceof HTMLElement)) return;

    toggleCardMobile(card);
  });

  document.addEventListener("keydown", (e) => {
    if (!isSmallScreen()) return;
    if (e.key !== "Enter" && e.key !== " ") return;

    const card = document.activeElement?.closest?.(".flip-card");
    if (!(card instanceof HTMLElement)) return;

    e.preventDefault();
    toggleCardMobile(card);
  });

  window.addEventListener("resize", requestReflow, { passive: true });
</script>