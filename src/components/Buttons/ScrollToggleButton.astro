---
// Scroll-based button with automatic visibility toggling
import EnsoButton from './EnsoButton.astro';

interface Props {
  className?: string;
  showOnScroll?: boolean; // true = show after scrolling, false = show before scrolling
  title?: string;
  href?: string;
  direction?: 'up' | 'down' | 'left' | 'right';
}

const { className = '', showOnScroll = false, title, href, direction = 'up' } = Astro.props;
---

<div class={`scroll-toggle ${className} ${showOnScroll ? 'show-on-scroll' : 'show-on-top'}`}>
  <!-- Render a single EnsoButton; it gracefully ignores undefined props -->
  <EnsoButton
    direction={direction}
    className={`btn ${className}`}
    href={href}
    title={title}
  />
</div>

<style lang="scss" scoped>
  .scroll-toggle {
    position: fixed;
    z-index: 1000;
    transition: opacity 0.3s ease;

    /* Initial state: show on top */
    opacity: 1;
    pointer-events: auto;

    /* Show on scroll */
    &.show-on-scroll {
      opacity: 0;
      pointer-events: none;
    }

    /* Dynamic classes from JavaScript */
    &.visible {
      opacity: 1;
      pointer-events: auto;
    }

    &.hidden {
      opacity: 0;
      pointer-events: none;
    }

    &.up {
      bottom: calc(var(--section-padding) / 2);
      right: calc(var(--section-padding) / 2);

      @media (min-width: 600px) {
        right: calc(var(--section-padding) - var(--btn-size));
      }
    }

    &.down {
      bottom: calc(var(--section-padding) / 2);
      left: 50%;
      transform: translateX(-50%);

      .btn::after {
        transform: rotate(180deg);
      }
    }
  }
</style>

<script>
  // Scroll-based visibility logic
  function updateButtonVisibility() {
    const buttons = document.querySelectorAll('[class*="scroll-toggle"]');
    const isScrolled = window.scrollY > 100;

    buttons.forEach(button => {
      const isShowOnScroll = button.classList.contains('show-on-scroll');
      const shouldBeVisible = isShowOnScroll ? isScrolled : !isScrolled;

      if (shouldBeVisible) {
        button.classList.remove('hidden');
        button.classList.add('visible');
      } else {
        button.classList.remove('visible');
        button.classList.add('hidden');
      }
    });
  }

  // Add event listener
  window.addEventListener('scroll', updateButtonVisibility);

  // Initial check
  updateButtonVisibility();

  // Smooth scroll for anchor-based EnsoButtons inside .scroll-toggle
  function initSmoothScroll() {
    document.querySelectorAll('.scroll-toggle a.enso[href^="#"]').forEach(a => {
      if ((a).__smoothInit) return;
      (a).__smoothInit = true;
      a.addEventListener('click', function (e) {
        const href = a.getAttribute('href');
        if (!href || !href.startsWith('#')) return;
        const target = href === '#' || href === '#top' ? document.documentElement : document.querySelector(href);
        if (target) {
          e.preventDefault();
          // Use scrollIntoView for smooth behavior; prefer start so header doesn't overlap
          try {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          } catch (err) {
            // fallback
            window.scrollTo({ top: 0, behavior: 'smooth' });
          }
        }
      });
    });
  }

  initSmoothScroll();
  document.addEventListener('DOMContentLoaded', initSmoothScroll);
</script>