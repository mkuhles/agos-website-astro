---
const { images = [], dojoName } = Astro.props;
import EnsoButton from '../Buttons/EnsoButton.astro';
import LeftButton from '../Buttons/LeftButton.astro';
import RightButton from '../Buttons/RightButton.astro';
import Section from '../sections/Section.astro';
---

{images.length > 0 ? (
  <Section id="dojo-gallery" type="content">
    <div data-dojo-gallery>
      <div class="dojo-gallery">
        <h2 class="section__title">Bilder</h2>
        <div class="gallery-slider" data-slider>
          <EnsoButton
            className="left slider-btn prev"
            direction="left"
            title="Vorheriges Bild"
            eventName="gallery-prev" 
            aria-label="Vorheriges Bild" />
          <div class="slider-track">
            {images.map((src: string, i: number) => (
              <button class="slider-item" data-index={i} aria-label={`Bild ${i + 1}`}>
                <img src={src} alt={`Impression ${i + 1} von ${dojoName}`} />
              </button>
            ))}
          </div>
          <EnsoButton
            className="right slider-btn next"
            direction="right"
            title="Nächstes Bild"
            eventName="gallery-next"
            aria-label="Nächstes Bild" />
        </div>
      </div>

      <div class="lightbox" data-lightbox hidden>
        <button class="lightbox-close" aria-label="Schließen">✕</button>
        <button class="lightbox-prev" aria-label="Vorheriges">‹</button>
        <img class="lightbox-img" src="" alt="" />
        <button class="lightbox-next" aria-label="Nächstes">›</button>
      </div>
    </div>
  </Section>
) : null}


<style is:global>
.gallery-slider {
  position: relative;
  display: flex;
  align-items: center;
}
.slider-track {
  display: flex;
  gap: 1rem;
  overflow: hidden;
  scroll-behavior: smooth;
}
.slider-item {
  border: none;
  padding: 0;
  background: transparent;
  cursor: pointer;
  flex: 0 0 auto;
}
.slider-item img {
  display: block;
  height: 16rem;
  width: auto;
}
.slider-btn {
  background-color: rgba(255,255,255,0.3) !important;
  border: none;
  padding: 0.5rem 0.8rem;
  cursor: pointer;
  font-size: 1.6rem;
  top: 50%;
  z-index: 1;

  &.left {
    position: absolute;
    left: 0;
    transform: translate(-50%,-50%);
  }
  &.right {
    position: absolute;
    right: 0;
    transform: translate(50%,-50%);
 }
}
.lightbox {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.8);
  z-index: 9999;
}
.lightbox[hidden] { display: none; }
.lightbox-img {
  max-width: min(90vw, 1200px);
  max-height: 90vh;
}
.lightbox-close,
.lightbox-prev,
.lightbox-next {
  position: absolute;
  background: transparent;
  color: #fff;
  border: none;
  font-size: 2rem;
  cursor: pointer;
}
.lightbox-close { top: 1rem; right: 1rem; }
.lightbox-prev { left: 1rem; }
.lightbox-next { right: 1rem; }
</style>
