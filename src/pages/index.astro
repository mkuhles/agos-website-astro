---
import { getCollection } from 'astro:content';
import { getDojos } from '../lib/getDojos';
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionContent from "../components/sections/SectionContent.astro";
import SectionFAQ from "../components/sections/SectionFAQ.astro";
import SectionFirst from "../components/sections/SectionFirst/SectionFirst.astro";
import SectionContact from "../components/sections/SectionContact.astro";
import SectionDojos from '../components/sections/SectionDojos.astro';

const dojos = await getDojos();
const agos = await getCollection('agos').then( (entries) => entries.find( (entry) => entry.slug === 'agos' ) ) ;
if(!agos) {
  throw new Error("AGOS entry not found in content collection 'agos'");
}
---

<BaseLayout pageTitle={agos.data.name} showHeader={false}>
  <SectionFirst agos={agos} dojos={dojos} />
  <SectionContent id="agos" class="about-section" content={agos} />
  <SectionFAQ />
  <SectionContact />
  <!-- <SectionDojos /> -->
</BaseLayout>


