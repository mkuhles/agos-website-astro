---
import { type CollectionEntry } from 'astro:content';
import { getDojos } from '../../lib/getDojos';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/sections/Section.astro';
import DojoGallery from '../../components/DojoGallery/DojoGallery.astro';
import fs from 'fs';
import path from 'path';

export async function getStaticPaths() {
  const dojos = await getDojos();

  return dojos
    .map((dojo) => ({
      params: { dojo: dojo.slug },
      props: { dojo },
    }));
}

interface Props {
  dojo: CollectionEntry<'dojos'>;
}

const { dojo } = Astro.props;
const { Content } = await dojo.render();


// collect impression images from public/assets/dojos/<slug>/ if present
let dojoImages = [];
try {
  const imagesPath = path.join(process.cwd(), 'public', 'assets', 'dojos', dojo.slug);
  const files = fs.readdirSync(imagesPath);
  dojoImages = files
    .filter((f) => /\.(jpe?g|png|webp|gif)$/i.test(f))
    .map((f) => `/assets/dojos/${dojo.slug}/${f}`);
} catch (err) {
  dojoImages = [];
}
---

<BaseLayout pageTitle={dojo.data.name}>
  <Section id="dojo-description" className="dojo-description" type="content">
    <h1 class="section__title">{dojo.data.name}</h1>
    <div class="dojo-description">
        {dojo.data.logo && (
          <div class="dojo-logo">
            <img src={dojo.data.logo} alt={"Logo von " + dojo.data.name} />
          </div>
        )}
        <Content />
    </div>
  </Section>

  {dojo.data.image && (
    <Section id="dojo-impressions" className="dojo-impressions" type="content">
      <div class="dojo-impressions">
        <img src={dojo.data.image} alt={"Dojo " + dojo.data.name} />
        <div>Impressionen aus dem Dojo</div>
      </div>
    </Section>
  )}
  <DojoGallery images={dojoImages} dojoName={dojo.data.name} />

  {dojo.data.trainings.length > 0 && (
    <Section id="dojo-trainings" type="content">
      <div class="dojo-trainings">
        <h2 class="section__title">Trainingszeiten</h2>
        <div class="dojo-trainings__content">
          {dojo.data.trainings.map((day) => (
            <div class="dojo-trainings__day">
              <div class="dojo-training__day-of-the-week">{day.day}</div>
              {day.slots.map((slot) => (
                <div class="dojo-training">
                  <div class="dojo-training__time">{slot.time}</div>
                  <div class="dojo-training__title">{slot.title}</div>
                </div>
              ))}
            </div>
          ))}
        </div>
      </div>
      
      {dojo.data.trainingsNotes && (
        <div class="dojo-training__notes">{dojo.data.trainingsNotes}</div>
      )}
    </Section>
  )}
</BaseLayout>


<style is:global>
.dojo-logo {
  /* Mobile-first: centered and stacked under text */
  float: none;
  margin: 0 auto 1rem;
  text-align: center;
  max-width: 12rem;
}
.dojo-logo img {
  display: block;
  max-width: 100%;
  height: auto;
}

@media (min-width: 768px) {
  .dojo-logo {
    /* Desktop: float right and allow text to wrap */
    float: right;
    margin: 0 0 1rem 1rem;
    max-width: 18rem;
    text-align: right;
  }
}
.dojo-trainings {
  background-image: url('/assets/trainings.png');
  background-position: right top;
  background-size: 10rem auto;
  background-repeat: no-repeat;
  padding-right: 10rem;
  box-sizing: border-box;
  max-width: 27rem;
  /* sonst ist das Bild abgeschnitten */
  min-height: 15rem; 
  margin: auto;
}
.dojo-impressions {
  text-align: center;
}
.dojo-impressions img {
  max-width: min(40rem, 100%);
  margin: auto;
}

.dojo-training {
  margin-bottom: 1rem;
}
.dojo-training__day-of-the-week {
  font-weight: bold;
  margin-bottom: 0.5rem;
  font-size: 1.5rem;
  text-transform: uppercase;
}
.dojo-training__time {
  font-size: 1.2rem;
  font-weight: bold;
}
.dojo-training__title {
  max-width: 15em;
}
.dojo-training__notes {
  font-style: italic;
  margin-top: 0.5rem;
}

</style>
